# SEC EDGAR (required for live ingest)
SEC_USER_AGENT=AlphaLens you@example.com

# Backend URL for Next.js BFF (frontend server-side only)
ALPHALENS_API_BASE_URL=http://localhost:8000

# OpenAI — enabled by default when key is set; set ALPHALENS_LLM_SYNTHESIS=0 to disable
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ALPHALENS_LLM_SYNTHESIS=1
ALPHALENS_LLM_MODEL=gpt-4.1-mini
ALPHALENS_EXTERNAL_EMBEDDINGS=1
ALPHALENS_EMBEDDING_MODEL=text-embedding-3-small

# Demo mode: serve pre-ingested fixture filings (no SEC ingest required)
ALPHALENS_DEMO_MODE=0
